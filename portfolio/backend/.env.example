# ── Server ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS — comma-separated allowed origins ────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://ayushman.dev

# ── Email (Nodemailer / Gmail App Password) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
MAIL_TO=your@gmail.com
MAIL_FROM="Ayushman Portfolio <your@gmail.com>"

# ── GitHub (optional — increases rate limit from 60 to 5000/hr) ───────
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_USERNAME=ayushman-git

# ── Admin (for /api/analytics and /api/resume/downloads) ─────────────
ADMIN_SECRET=change_this_to_a_random_string_in_production
